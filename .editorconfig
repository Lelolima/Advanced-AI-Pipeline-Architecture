[*.md]
text = true
end_of_line = lf
trim_trailing_whitespace = true

[*.json]
indent_style = space
indent_size = 2

[*.ts]
indent_style = space
indent_size = 2
end_of_line = crlf

[*.tsx]
indent_style = space
indent_size = 2
end_of_line = crlf

[*.js]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.html]
indent_style = space
indent_size = 2